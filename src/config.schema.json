{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RouteWatch Config",
  "type": "object",
  "properties": {
    "appDir": {
      "type": "string",
      "description": "Path to the Next.js app directory"
    },
    "output": {
      "type": "string",
      "enum": ["text", "json", "markdown"],
      "description": "Output format for the diff report"
    },
    "reportFile": {
      "type": "string",
      "description": "Optional file path to write the report to"
    },
    "watch": {
      "type": "boolean",
      "description": "Enable watch mode"
    },
    "cache": {
      "type": "boolean",
      "description": "Enable route scan caching"
    },
    "filter": {
      "type": "object",
      "description": "Route filtering options",
      "properties": {
        "include": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for routes to include"
        },
        "exclude": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob patterns for routes to exclude"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
